# odoodev-equitania v0.4.49 | python/uv
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
▸ Setup:    uv venv --python 3.12 && venv+ && uv pip install -e ".[dev]"
▸ Run:      odoodev --help
▸ Test:     pytest
