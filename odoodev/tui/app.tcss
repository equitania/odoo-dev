/* TUI layout for odoodev Odoo server runtime */

Screen {
    layout: vertical;
}

#status-bar {
    height: 1;
    dock: top;
    background: $primary-background;
}

#filter-bar {
    height: 1;
    dock: top;
    padding: 0 1;
    background: $surface;
}

#log-viewer {
    height: 1fr;
}

#log-output {
    height: 1fr;
    scrollbar-size: 1 1;
}

Footer {
    dock: bottom;
}
